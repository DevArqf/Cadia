{
	"name": "bot",
	"projectType": "application",
	"root": "apps/bot",
	"sourceRoot": "apps/bot/src",
	"targets": {
		"start": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm --workspace @cadia/bot start"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm --workspace @cadia/bot test"
			}
		}
	},
	"implicitDependencies": ["ipc"]
}

{
	"name": "cadia",
	"version": "6.8.5",
	"private": true,
	"main": "apps/bot/src/index.js",
	"author": "@DevArqf",
	"license": "UNLICENSE",
	"type": "commonjs",
	"packageManager": "npm@11.15.0",
	"workspaces": [
		"apps/bot",
		"apps/dashboard",
		"libs/*"
	],
	"dependencies": {
		"@iamtraction/google-translate": "^1.1.2",
		"@napi-rs/canvas": "^1.0.0",
		"@sapphire/discord-utilities": "^3.2.2",
		"@sapphire/discord.js-utilities": "7.1.6",
		"@sapphire/fetch": "^3.0.2",
		"@sapphire/framework": "^5.0.7",
		"@sapphire/plugin-api": "^6.1.1",
		"@sapphire/plugin-editable-commands": "^4.0.4",
		"@sapphire/plugin-logger": "^4.0.2",
		"@sapphire/plugin-subcommands": "^6.0.3",
		"@sapphire/time-utilities": "^1.7.12",
		"@sapphire/utilities": "^3.15.3",
		"@skyra/env-utilities": "^1.3.0",
		"axios": "^1.6.7",
		"beautify": "^0.0.8",
		"cli-progress": "^3.12.0",
		"discord-api-types": "0.38.48",
		"discord-gamecord": "^4.4.4",
		"discord.js": "^14.14.1",
		"figlet": "^1.7.0",
		"jszmq": "^0.1.2",
		"mathjs": "^15.2.0",
		"mysql2": "^3.22.4",
		"os": "^0.1.2",
		"sourcebin_js": "^0.0.3-ignore",
		"util": "^0.12.5"
	},
	"devDependencies": {
		"@sapphire/cli": "^1.9.3",
		"@sapphire/prettier-config": "^2.0.0",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"madge": "^8.0.0",
		"nodemon": "^3.0.3",
		"npm-run-all2": "^6.1.1",
		"nx": "^23.0.1",
		"prettier": "^3.8.3"
	},
	"scripts": {
		"sapphire": "npm --workspace @cadia/bot run sapphire",
		"generate": "npm --workspace @cadia/bot run generate",
		"watch": "npm --workspace @cadia/bot run watch",
		"prestart": "npm test",
		"start": "npm run start:bot",
		"start:bot": "npm --workspace @cadia/bot start",
		"start:dashboard": "npm --workspace @cadia/dashboard start",
		"dev:dashboard": "npm --workspace @cadia/dashboard dev",
		"test": "npm --workspace @cadia/bot test",
		"test:fast": "npm --workspace @cadia/bot run test:fast",
		"check:cycles": "npm --workspace @cadia/bot run check:cycles",
		"check:cycles:monorepo": "madge --circular --extensions js,cjs,mjs,ts,tsx apps libs",
		"check:cycles:libs": "madge --circular --extensions js,cjs,mjs libs",
		"check:cycles:libs:ts": "madge --circular --extensions ts,tsx libs/",
		"graph": "nx graph",
		"lint:cycles": "eslint \"apps/**/*.js\" \"libs/**/*.js\" --no-warn-ignored",
		"format": "prettier --write \"apps/bot/src/**/*.js\""
	},
	"prettier": "@sapphire/prettier-config",
	"overrides": {
		"undici": "6.27.0",
		"uuid": "^11.1.1"
	}
}
